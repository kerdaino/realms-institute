# Use an sk_test_xxx key while testing. Use sk_live_xxx only in production.
PAYSTACK_SECRET_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. Set this only after a REALMS subaccount has been created in Paystack.
PAYSTACK_REALMS_SUBACCOUNT=

NEXT_PUBLIC_REALMS_CONTACT_EMAIL=gloryrealm2025@gmail.com

# Safe for frontend usage, but currently used only by the server-side admin client.
NEXT_PUBLIC_SUPABASE_URL=

# Server only. Never expose this service role key to browser or client-side code.
SUPABASE_SERVICE_ROLE_KEY=

# Server only. RESEND_API_KEY is required for email sending.
RESEND_API_KEY=

# Server only. RESEND_FROM_EMAIL must use the verified Resend domain.
RESEND_FROM_EMAIL="REALMS Institute <admissions@mail.grccglobal.org>"

# Server only. REALMS_ADMIN_EMAIL receives admin notifications and replies.
REALMS_ADMIN_EMAIL=gloryrealm2025@gmail.com

# If Resend is not configured, registration/payment should still work.

# Temporary launch protection for the registration admin area.
REALMS_ADMIN_PASSWORD=
